// Compile-time cost of a Fix tree, as a function of size.
//
// Generated by CMake (configure_file) with @BENCH_N@ substituted per
// size; each generated translation unit is compiled on its own so the
// build telemetry records one `compile` event per (kind, size). The
// control is ct_plain.cpp.in, which does the same work with no Fix,
// no functor typeclass, and no recursion verbs.
//
// The concern this rebuts: that Fix explodes template instantiation.
// It does not. Fix<F> ties the recursive knot with a *single* recursive
// type — the child position of BinaryTreeF is always Fix<F>, never a
// fresh instantiation per node — so the number of distinct template
// instantiations is O(1) in the tree size. What grows with @BENCH_N@ is
// the constexpr *evaluation* the compiler runs to build and fold the
// tree, and that grows linearly. Plotting compile time against size
// across the generated TUs is meant to show a straight line, tracking
// the control, not a template-instantiation blow-up.

#include <beman/tree_algorithms/binary_tree.hpp>

#include <cstddef>
#include <cstdint>
#include <utility>

namespace {

constexpr std::size_t kNodes = @BENCH_N@;

using beman::tree_algorithms::BinaryTreeF;
using beman::tree_algorithms::BinaryTreeFix;
using beman::tree_algorithms::BinaryTreeLayer;
using beman::tree_algorithms::child_slot_t;
using beman::tree_algorithms::fold_fix;
using beman::tree_algorithms::make_slot;
using beman::tree_algorithms::unfold_fix;

using Layer = BinaryTreeLayer<std::int64_t>;
using Range = std::pair<std::size_t, std::size_t>;

// Build a balanced Fix tree over [0, kNodes) and fold it to the sum of
// its node values — all at compile time.
constexpr auto build_and_sum() -> std::int64_t {
    auto coalgebra = [](const Range& r) -> BinaryTreeF<std::int64_t, Range> {
        auto [lo, hi]   = r;
        std::size_t mid = lo + (hi - lo) / 2;
        return BinaryTreeF<std::int64_t, Range>{
            static_cast<std::int64_t>(mid),
            mid > lo ? make_slot<Range>(Range{lo, mid}) : child_slot_t<Range>{},
            hi > mid + 1 ? make_slot<Range>(Range{mid + 1, hi}) : child_slot_t<Range>{}};
    };
    auto tree    = unfold_fix<Layer::template F>(coalgebra, Range{0, kNodes});
    auto sum_alg = [](const BinaryTreeF<std::int64_t, std::int64_t>& layer) -> std::int64_t {
        std::int64_t total = layer.value;
        if (layer.left) {
            total += *layer.left;
        }
        if (layer.right) {
            total += *layer.right;
        }
        return total;
    };
    return fold_fix<std::int64_t>(sum_alg, tree);
}

// Sum of 0 .. kNodes-1, the answer the compiler must arrive at.
static_assert(build_and_sum() ==
              static_cast<std::int64_t>(kNodes) * (static_cast<std::int64_t>(kNodes) - 1) / 2);

} // namespace

int main() { return 0; }
